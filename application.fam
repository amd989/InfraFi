App(
    appid="infrafi",
    name="InfraFi",
    apptype=FlipperAppType.EXTERNAL,
    entry_point="wi_fir_app",
    requires=["gui", "notification", "storage", "nfc"],
    stack_size=8 * 1024,
    fap_version=(1, 0),
    fap_author="amd989",
    fap_icon="flipper/images/wifi_10px.png",
    fap_icon_assets="flipper/images",
    fap_category="Infrared",
    fap_description="Transmit WiFi credentials via IR to a Linux server",
    sources=["*.c*", "!daemon"],
)
